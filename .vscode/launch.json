{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: test drag n drop",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/apt-gcode converter 1.py",
            "args": ["${workspaceFolder}/dwelltest.txt", "tokarilica"],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
